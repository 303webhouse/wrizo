{
  "name": "@writer-studio/desktop",
  "version": "0.0.1",
  "main": "./dist/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"node scripts/wait-and-electron.mjs\"",
    "build": "vite build && tsc src/main.ts src/preload.ts --outDir dist --declaration false --module commonjs --target es2020 --skipLibCheck --esModuleInterop --moduleResolution node",
    "build:web": "vite build --outDir dist-web --emptyOutDir"
  },
  "dependencies": {
    "@fontsource-variable/figtree": "^5.2.10",
    "@fontsource-variable/newsreader": "^5.2.10",
    "@fontsource/courier-prime": "^5.2.8",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.13.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "electron": "31.0.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  }
}
