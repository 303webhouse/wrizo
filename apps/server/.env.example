# Copy to apps/server/.env for local dev. NEVER commit the real .env.
# Values below are placeholders — fill with your own (never the trading-hub's).

# Postgres connection string (a NEW database, never the trading-hub's).
DATABASE_URL=postgres://user:password@host:5432/writer_studio

# 32+ random bytes, e.g. `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
SESSION_SECRET=replace-with-32-plus-random-bytes

# Registration gate handed to testers.
INVITE_CODE=replace-with-an-invite-code

# Port the server listens on (Railway sets PORT automatically).
PORT=3000

# Set to "production" on Railway; leave unset/development locally.
NODE_ENV=development

# TU1/TU2 — the Tutor's model plumbing. All four are OPTIONAL: leave
# TUTOR_API_KEY unset and the Tutor's conversation responds with a plain
# "not configured" state (the lenses still work — they're fully client-side).
# Provider-agnostic by design (TU2 S1): the route speaks Anthropic's own
# message format, so any Anthropic-compatible endpoint slots in behind
# TUTOR_BASE_URL the same way DeepSeek does below — this is the pre-cut
# seam for the later TU6 Accounts ticket (BYO keys / provider picker).
# TUTOR_API_KEY=replace-with-your-provider-api-key
# TUTOR_BASE_URL=https://api.deepseek.com/anthropic
# TUTOR_MODEL=deepseek-v4-flash
# TUTOR_MAX_TOKENS=700
